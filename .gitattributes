# Auto-detect text files and normalize line endings
* text=auto

# Force LF line endings for all text files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sol text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files (don't diff)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Lock files — track but don't diff
package-lock.json -diff
pnpm-lock.yaml -diff

# Solidity ABIs — generated, don't diff
**/artifacts/**/*.json -diff
**/typechain-types/** -diff linguist-generated
