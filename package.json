{
  "name": "probly",
  "version": "0.1.0",
  "description": "Probly — Prediction market super-aggregator for BNB Chain",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "generate-probable-key": "tsx scripts/generate-probable-key.ts",
    "dev:api": "pnpm dlx nx serve api",
    "dev:web": "pnpm dlx nx dev web",
    "dev:mock": "tsx apps/mock-api/src/main.ts",
    "seed": "tsx scripts/test-seed.ts",
    "build": "pnpm dlx nx run-many -t build",
    "test": "pnpm dlx nx run-many -t test",
    "lint": "pnpm dlx nx run-many -t lint"
  },
  "packageManager": "pnpm@9.0.0",
  "keywords": [
    "bnb",
    "prediction-markets",
    "aggregator",
    "probly"
  ],
  "license": "MIT",
  "dependencies": {
    "@prob/clob": "^0.5.0",
    "@prob/core": "^0.3.0",
    "@prob/types": "^0.0.1",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "viem": "^2.46.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "nx": "^21.3.2",
    "typescript": "^5.8.3"
  }
}
