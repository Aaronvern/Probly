    "@prob/types": "^0.0.1",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "viem": "^2.46.3"
  },
  "devDependencies": {
    "nx": "^21.3.2",
    "typescript": "^5.8.3"
  }
}
