{
  "name": "probly",
  "version": "0.1.0",
  "description": "Probly — Prediction market super-aggregator for BNB Chain",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "generate-probable-key": "tsx scripts/generate-probable-key.ts",
    "dev:api": "npx nx serve api",
    "dev:web": "npx nx dev web",
