{
  "name": "mcp-server",
  "sourceRoot": "apps/mcp-server/src",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx watch apps/mcp-server/src/main.ts"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/mcp-server/tsconfig.json"
      }
    }
  }
}
