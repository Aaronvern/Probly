{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@probly/sdk": ["packages/sdk/src/index.ts"],
      "@probly/sdk/*": ["packages/sdk/src/*"],
      "@probly/contracts": ["packages/contracts/src/index.ts"],
      "@probly/config": ["packages/config/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "build"]
}
